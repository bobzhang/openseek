///|
async fn main {
  if wants_stdin() {
    let buffer = StringBuilder::new()
    while @stdio.stdin.read_until("\n") is Some(line) {
      buffer.write_string(line)
      buffer.write_char('\n')
    }
    @stdio.stdout.write("stdin:" + buffer.to_string())
  } else {
    @stdio.stdout.write("moon-cmd-ok\n")
  }
}

///|
fn wants_stdin() -> Bool {
  for arg in @env.args() {
    if arg == "--stdin" {
      return true
    }
  }
  false
}
